<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Settings Button (top-right) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabSettings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:src="@drawable/ic_settings"
        app:fabSize="mini"
        app:backgroundTint="@color/card_bg"
        app:tint="@color/text_dim"
        app:layout_anchor="@id/scrollView"
        app:layout_anchorGravity="top|end"
        android:contentDescription="设置" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center_horizontal">

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🇱🇦 ↔ 🇨🇳 老挝语翻译"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginTop="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="原生应用 · 语音输入 · 语音播报"
                android:textSize="13sp"
                android:textColor="@color/text_dim"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="20dp" />

            <!-- Offline Model Bar -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardOffline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/amber"
                app:strokeWidth="1dp"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="📦 离线翻译模型"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/tvOfflineStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="未加载"
                            android:textSize="12sp"
                            android:textColor="@color/amber"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="10dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDownloadModel"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="下载模型"
                            android:textSize="12sp"
                            app:strokeColor="@color/amber"
                            android:textColor="@color/amber"
                            android:layout_marginEnd="8dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnImportModel"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="导入本地"
                            android:textSize="12sp"
                            app:strokeColor="@color/blue"
                            android:textColor="@color/blue"
                            android:layout_marginEnd="8dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDeleteModel"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="删除"
                            android:textSize="12sp"
                            app:strokeColor="@color/red"
                            android:textColor="@color/red"
                            android:visibility="gone" />
                    </LinearLayout>

                    <!-- Download Progress -->
                    <ProgressBar
                        android:id="@+id/progressDownload"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:visibility="gone"
                        android:max="100" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Language Selector -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLangLoZh"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:text="老挝语 → 中文"
                    android:textSize="13sp"
                    app:cornerRadius="20dp"
                    app:backgroundTint="@color/blue" />

                <ImageButton
                    android:id="@+id/btnSwap"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/swap_bg"
                    android:src="@drawable/ic_swap"
                    android:layout_marginHorizontal="12dp"
                    android:contentDescription="交换语言"
                    app:tint="@color/text_dim" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLangZhLo"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:text="中文 → 老挝语"
                    android:textSize="13sp"
                    app:cornerRadius="20dp"
                    app:strokeColor="@color/border"
                    android:textColor="@color/text_primary" />
            </LinearLayout>

            <!-- Engine Selector -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="引擎:"
                    android:textSize="12sp"
                    android:textColor="@color/text_dim"
                    android:layout_marginEnd="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEngineAuto"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="自动"
                    android:textSize="12sp"
                    app:cornerRadius="16dp"
                    app:backgroundTint="@color/blue"
                    android:layout_marginEnd="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEngineBaidu"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="百度"
                    android:textSize="12sp"
                    app:cornerRadius="16dp"
                    app:strokeColor="@color/border"
                    android:textColor="@color/text_primary"
                    android:layout_marginEnd="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEngineOffline"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="离线"
                    android:textSize="12sp"
                    app:cornerRadius="16dp"
                    app:strokeColor="@color/border"
                    android:textColor="@color/text_primary" />
            </LinearLayout>

            <!-- Source & Output Panels -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">

                <!-- Source Panel -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/card_bg"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/border"
                    app:strokeWidth="1dp"
                    android:layout_marginEnd="7dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="9dp"
                            android:gravity="center_vertical"
                            android:background="@color/panel_header_bg">

                            <TextView
                                android:id="@+id/tvSrcLang"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="老挝语"
                                android:textSize="13sp"
                                android:textColor="@color/text_dim" />

                            <TextView
                                android:id="@+id/tvCharCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="13sp"
                                android:textColor="@color/text_dim" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/border" />

                        <EditText
                            android:id="@+id/etSource"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="170dp"
                            android:padding="16dp"
                            android:background="@null"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:textSize="16sp"
                            android:lineSpacingExtra="4dp"
                            android:gravity="top"
                            android:inputType="textMultiLine"
                            android:hint="输入文字，或按🎤说话..."
                            android:importantForAutofill="no" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Output Panel -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/card_bg"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/border"
                    app:strokeWidth="1dp"
                    android:layout_marginStart="7dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="9dp"
                            android:gravity="center_vertical"
                            android:background="@color/panel_header_bg">

                            <TextView
                                android:id="@+id/tvTgtLang"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="中文"
                                android:textSize="13sp"
                                android:textColor="@color/text_dim" />

                            <TextView
                                android:id="@+id/tvEngineTag"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/border" />

                        <TextView
                            android:id="@+id/tvOutput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="170dp"
                            android:padding="16dp"
                            android:text="翻译结果将显示在这里"
                            android:textSize="16sp"
                            android:lineSpacingExtra="4dp"
                            android:textColor="@color/text_hint"
                            android:gravity="top" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Error Message -->
            <TextView
                android:id="@+id/tvError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:background="@drawable/error_bg"
                android:textColor="@color/red_light"
                android:textSize="14sp"
                android:visibility="gone"
                android:layout_marginBottom="10dp" />

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <!-- Voice Input -->
                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/fabVoice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_mic"
                    app:fabSize="mini"
                    app:backgroundTint="@color/card_bg"
                    app:tint="@color/red"
                    android:layout_marginEnd="14dp"
                    android:contentDescription="语音输入" />

                <!-- Translate Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTranslate"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="翻  译"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="10dp"
                    android:background="@drawable/translate_btn_bg"
                    android:textColor="@android:color/white" />

                <!-- Speak Result -->
                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/fabSpeak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_speaker"
                    app:fabSize="mini"
                    app:backgroundTint="@color/card_bg"
                    app:tint="@color/green"
                    android:layout_marginStart="14dp"
                    android:contentDescription="播放" />

                <!-- Copy Result -->
                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/fabCopy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_copy"
                    app:fabSize="mini"
                    app:backgroundTint="@color/card_bg"
                    app:tint="@color/amber"
                    android:layout_marginStart="10dp"
                    android:contentDescription="复制" />
            </LinearLayout>

            <!-- Voice Hint -->
            <TextView
                android:id="@+id/tvVoiceHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/text_dim"
                android:layout_marginTop="4dp"
                android:minHeight="18dp" />

            <!-- Status Bar -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/text_dim"
                android:layout_marginTop="8dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
